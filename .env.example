# API 設定
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# 路徑設定
DOWNLOAD_OUTPUT_DIR=/data/downloads
TEMP_DIR=/data/temp

# Docker 映射
NGINX_PORT=80
NGINX_SSL_PORT=443
APP_PORT=8000

# 預設值
DEFAULT_QUALITY=original
MAX_CONCURRENT_DOWNLOADS=5
TASK_TIMEOUT_SECONDS=300

# Playwright
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright